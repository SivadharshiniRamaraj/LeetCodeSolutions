import java.util.*;
class Solution {
    public boolean isPalindrome(int x) {
        if(x<0){
            return false;
        }
        String s=Integer.toString(x);
        String h="";
        for(int i=s.length()-1;i>=0;i--)
        {
         h+=s.charAt(i);
        }
        long m=Long.parseLong(h);
        if(x==m)
        {
            return true;
        }
        else
        {
            return false;
        }
    }
}