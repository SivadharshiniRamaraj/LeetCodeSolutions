class Solution {
    public void sortColors(int[] nums) {
        
        HashMap<Integer,Integer> map=new HashMap<>();
        for(int i=0;i<nums.length;i++)
        {
            map.put(nums[i],map.getOrDefault(nums[i],0)+1);
        }
        int j=0,m=0;
        for(int i=0;i<3;i++)
        {
            j=map.getOrDefault(i,0);
            while(j>0)
            {
                nums[m]=i;
                j--;
                m++;
            }
        }
    }
}