class Solution {
    public int maximumCount(int[] nums) {
        int oc=0,ec=0;
        for(int i=0;i<nums.length;i++)
        {
            if(nums[i]<0)
            {
                oc++;
            }
            else if(nums[i]>0)
            {
                ec++;
            }
        }
        return ec>oc?ec:oc;
    }
}